# Copy this file to .env and fill in real values before running
# `docker compose up`. Never commit the real .env file.

# Port on the Docker host that maps to the app's internal nginx (8080).
# Change if 8080 is already in use on your host, or if a reverse proxy
# expects a different upstream port.
APP_PORT=8080

# Show detailed error output in HTTP responses. Keep false in any
# environment other than local development.
APP_DEBUG=false

# If true, viewing the map (not just uploading/editing) requires login.
# If false, the map is publicly viewable on your internal network and only
# upload/edit/delete require authentication.
REQUIRE_AUTH_FOR_VIEW=false

# Whether the session cookie is marked Secure (HTTPS-only). Leave true if
# a reverse proxy terminates TLS in front of this app. Set false only for
# plain-HTTP local testing.
COOKIE_SECURE=true

# Created automatically on first boot if the users table is empty.
# Change the password after first login; these values are only consumed once.
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=change-me-before-first-boot

# Maximum accepted upload size in bytes (application-level check, in
# addition to the nginx/php.ini limits baked into the image).
MAX_UPLOAD_BYTES=10485760

# Base URL of a Nominatim-compatible geocoding search endpoint, used by the
# "Look up" button when adding/editing a Location.
GEOCODING_BASE_URL=https://nominatim.openstreetmap.org/search

# Nominatim's usage policy requires a real identifying User-Agent (not a
# generic library string) on every request, so they can contact you if your
# traffic causes problems. Set this to something identifying this
# deployment/operator.
GEOCODING_USER_AGENT=CircuitMap/1.0 (set-a-contact-email@example.com)

# Mount the app under a sub-path instead of the domain root, e.g.
# /circuitmap so it's reachable at https://host/circuitmap/. Leave empty to
# serve from "/". Must start with "/" and have no trailing slash. Assumes
# an external reverse proxy forwards the full path (including this prefix)
# through unchanged - it does not strip the prefix before forwarding.
BASE_PATH=

# Number of trusted reverse proxies between clients and this app, used to
# resolve the real client IP from X-Forwarded-For for rate limiting and
# audit logging. X-Forwarded-For is client-supplied and appended to by each
# proxy, so only the rightmost N entries (added by proxies you operate) are
# trustworthy. Set this to the count of your own proxies in the path
# (1 for a single reverse proxy, the default). Set it to 0 if the app is
# exposed directly with no proxy, so X-Forwarded-For is ignored entirely and
# REMOTE_ADDR is always used. Setting it too high lets a client spoof its IP.
TRUSTED_PROXY_COUNT=1

# --- Cacti network-monitoring integration -----------------------------------
# Circuit status (up/degraded/down) and current traffic can be pulled from a
# Cacti 1.2.x server by reading its MySQL/MariaDB database directly with a
# read-only account. Leave CACTI_DB_HOST empty to disable the integration.
#
# Grant the account SELECT on only what the poller reads, e.g.:
#   GRANT SELECT ON cacti.host TO 'circuitmap'@'%';
#   GRANT SELECT ON cacti.data_source_stats_hourly_last TO 'circuitmap'@'%';
#
# Per circuit, set the Cacti device id (from the Device edit page URL) on the
# circuit's edit form; optionally also a data source id and capacity to get
# traffic/utilization in the map popup. Traffic requires Cacti's DSStats
# feature to be enabled (Settings -> Data -> Data Source Statistics); device
# up/down status works without it.
CACTI_DB_HOST=
CACTI_DB_PORT=3306
CACTI_DB_NAME=cacti
CACTI_DB_USER=circuitmap
CACTI_DB_PASSWORD=

# Seconds between poll passes; match your Cacti poller interval (300 = 5 min).
CACTI_POLL_INTERVAL=300

# If a cacti-sourced status hasn't been refreshed for this many seconds
# (e.g. the Cacti DB is unreachable), it is flipped to "unknown" so the map
# never keeps showing a stale "up". Default allows ~3 missed polls.
CACTI_STALE_AFTER=900

# DSStats field names holding interface traffic. The stock Interface Traffic
# data templates use traffic_in/traffic_out; only change these if your
# templates use different internal data source names.
CACTI_TRAFFIC_IN_NAME=traffic_in
CACTI_TRAFFIC_OUT_NAME=traffic_out

# --- Reverse-proxy header authentication -----------------------------------
# If true, a request carrying PROXY_AUTH_HEADER logs the user in
# automatically (auto-provisioning an account on first sight), alongside
# the normal /login form which keeps working.
#
# DANGER: only enable this if a reverse proxy you control sits in front of
# this app on every network path AND that proxy strips/overwrites any
# client-supplied copy of PROXY_AUTH_HEADER before forwarding the request.
# If this app is ever reachable directly, or the proxy passes the header
# through unchecked, any client can set it themselves and log in as
# (or create) any account - full authentication bypass. Leave false
# unless you have verified that trust boundary.
PROXY_AUTH_ENABLED=false

# Header the reverse proxy sets to the authenticated user's username.
PROXY_AUTH_HEADER=REMOTE_USER

# Role assigned to accounts auto-provisioned via the proxy header. Must be
# "readonly", "editor", or "admin"; anything else falls back to "readonly".
PROXY_AUTH_DEFAULT_ROLE=readonly
